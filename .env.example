APIFY_TOKEN=
APIFY_X_ACTOR_ID=
APIFY_LOOKBACK_DAYS=2
APIFY_FETCH_LIMIT=80
# Optional: X actor raw JSON overrides (must be valid JSON string)
APIFY_X_INPUT_JSON=
# Optional: lock Weibo targets by uid or profile URL, e.g. {"周鸿祎":"1708942053"}
WEIBO_TARGET_UIDS_JSON=
# Optional: when actor returns 0, fetch recent posts per uid directly from m.weibo.cn timeline
WEIBO_FALLBACK_PER_USER=3
# Optional: use external weiboSpider-master output first (true/false)
WEIBO_EXTERNAL_SPIDER_ENABLED=false
# Optional: shell command to run external spider, e.g. "python3 weiboSpider-master/scripts/export_json.py"
WEIBO_EXTERNAL_SPIDER_CMD=
# Optional: JSON output path produced by external spider command
WEIBO_EXTERNAL_SPIDER_OUTPUT=
# Optional: command timeout in ms
WEIBO_EXTERNAL_SPIDER_TIMEOUT_MS=180000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
PROMPT_X_MAX_ITEMS=35
PROMPT_WEIBO_MAX_ITEMS=35
