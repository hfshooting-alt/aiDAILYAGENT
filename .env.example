APIFY_TOKEN=
APIFY_X_ACTOR_ID=
APIFY_WEIBO_ACTOR_ID=
APIFY_LOOKBACK_DAYS=2
APIFY_FETCH_LIMIT=80
# Optional: actor-specific raw JSON overrides (must be valid JSON string)
APIFY_X_INPUT_JSON=
APIFY_WEIBO_INPUT_JSON=
# Optional: lock Weibo targets by uid or profile URL, e.g. {"周鸿祎":"1708942053"}
WEIBO_TARGET_UIDS_JSON=
# Optional: when actor returns 0, fetch recent posts per uid directly from m.weibo.cn timeline
WEIBO_FALLBACK_PER_USER=3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
PROMPT_X_MAX_ITEMS=35
PROMPT_WEIBO_MAX_ITEMS=35
